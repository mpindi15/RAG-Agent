# Required: get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=xxxxx

# Model used for answer generation and eval judging. gemini-3.5-flash exists
# but its free tier is capped at 20 requests/day, which an eval run alone can
# exceed — gemini-2.5-flash has a much higher free-tier quota.
GEMINI_MODEL=gemini-2.5-flash

# Retrieval tuning
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
TOP_K=4

# Storage locations (relative to project root, or absolute paths in Docker)
DATA_DIR=./data
CHROMA_DIR=./data/chroma
UPLOADS_DIR=./data/uploads
SQLITE_PATH=./data/app.db

# App
APP_HOST=0.0.0.0
APP_PORT=8000
